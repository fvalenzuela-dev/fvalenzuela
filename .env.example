# Environment variables template for Next.js
# These NEXT_PUBLIC_* variables are embedded into the JavaScript bundle at build time.
# In this project, they are passed as Docker build arguments.

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Clerk URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/

# API Configurations
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_PYTHON_API_URL=